# Copy to .env and fill in as needed. Sentinel runs fully offline with the defaults below.

# --- LLM ---
# Leave ANTHROPIC_API_KEY blank to use the templated fallback (no network calls).
ANTHROPIC_API_KEY=
# Model used for brief + postmortem synthesis. Override to claude-opus-4-8 for higher quality.
SENTINEL_MODEL=claude-sonnet-5

# --- Integrations ---
# When true, all external systems (GitHub, Slack, metrics) use in-repo mock adapters.
SENTINEL_USE_MOCKS=true

# Real-integration credentials (only used when SENTINEL_USE_MOCKS=false). Blank for now.
GITHUB_TOKEN=
GITHUB_REPO=
SLACK_BOT_TOKEN=
SLACK_CHANNEL=
